{
  "manifest_version": 3,
  "name": "Crimsonhaven",
  "version": "3.0.0",
  "description": "Your anime sanctuary — runs entirely in your browser. No account, no server.",
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png",
    "192": "icons/android-chrome-192x192.png",
    "512": "icons/android-chrome-512x512.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/favicon-16x16.png",
      "32": "icons/favicon-32x32.png",
      "192": "icons/android-chrome-192x192.png"
    },
    "default_title": "Open Crimsonhaven"
  },
  "background": {
    "service_worker": "sw.js"
  },
  "permissions": ["storage", "declarativeNetRequest", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "web_accessible_resources": [
    {
      "resources": ["player.html", "index.extension.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "crimson_referer_rules",
        "enabled": true,
        "path": "rules/referer_rules.json"
      }
    ]
  }
}
